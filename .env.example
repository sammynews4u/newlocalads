# Local development environment example.
# Copy this file to .env and replace placeholders.
# Never commit .env to GitHub.

# Runtime database URL. For Vercel/serverless runtime, use the Supabase Transaction Pooler on port 6543.
DATABASE_URL=postgresql://postgres.jjucyadatlpruinptwdk:<YOUR_SUPABASE_DB_PASSWORD>@aws-0-eu-central-1.pooler.supabase.com:6543/postgres?sslmode=require

# Migration/admin database URL. Use the Supabase Direct Connection on port 5432 for local migrations.
DATABASE_MIGRATION_URL=postgresql://postgres:<YOUR_SUPABASE_DB_PASSWORD>@db.jjucyadatlpruinptwdk.supabase.co:5432/postgres?sslmode=require

# Authentication secret. Use a long random value, 32+ characters.
JWT_SECRET=<GENERATE_A_LONG_RANDOM_SECRET>
# AUTH_SECRET is also supported as an alias.
AUTH_SECRET=<OPTIONAL_SAME_VALUE_AS_JWT_SECRET>

# Local app URL
NEXT_PUBLIC_BASE_URL=http://localhost:3000

# Supabase public project values. These are optional unless a Supabase browser client is added.
NEXT_PUBLIC_SUPABASE_URL=https://jjucyadatlpruinptwdk.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_vcWrgdO6_1pB0CrmqrwcKQ_ZZv0I6Jf
NEXT_PUBLIC_SUPABASE_ANON_KEY=sb_publishable_vcWrgdO6_1pB0CrmqrwcKQ_ZZv0I6Jf

# Optional server-only Supabase key. Do not expose in client code.
SUPABASE_SERVICE_ROLE_KEY=<OPTIONAL_SERVER_ONLY_KEY>

# Production admin bootstrap
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=<STRONG_ADMIN_PASSWORD_AT_LEAST_12_CHARACTERS>
ADMIN_FIRST_NAME=Admin
ADMIN_LAST_NAME=User

# Database/Vercel runtime controls
DATABASE_POOL_MAX=5
DATABASE_SSL=true
DATABASE_IDLE_TIMEOUT_MS=5000
DATABASE_CONNECTION_TIMEOUT_MS=10000
DISABLE_RUNTIME_SCHEMA_SETUP=true
EXPOSE_API_ERRORS=false
SEED_DEMO_USERS=false

# Optional Cloudinary image upload settings
CLOUDINARY_CLOUD_NAME=<OPTIONAL>
CLOUDINARY_API_KEY=<OPTIONAL>
CLOUDINARY_API_SECRET=<OPTIONAL>
MAX_CAMPAIGN_IMAGE_SIZE_MB=5
CLOUDINARY_UPLOAD_FOLDER=local-ads/campaign-images
