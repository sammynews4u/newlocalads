# Local development environment example.
# Copy this file to .env and replace placeholders.
# Never commit .env to GitHub.

# ============================================
# DATABASE CONFIGURATION
# ============================================

# Runtime database URL. For Vercel/serverless runtime, use the Supabase Transaction Pooler on port 6543.
# Format: postgresql://postgres.PROJECT_REF.pooler.supabase.com:6543/postgres?sslmode=require
DATABASE_URL=postgresql://postgres.jjucyadatlpruinptwdk.pooler.supabase.com:6543/postgres?sslmode=require

# Migration/admin database URL. Use the Supabase Direct Connection on port 5432 for local migrations.
# Only needed if running migrations locally. For Vercel, use the pooler URL above.
# Format: postgresql://postgres:PASSWORD@db.PROJECT_REF.supabase.co:5432/postgres?sslmode=require
DATABASE_MIGRATION_URL=postgresql://postgres:YOUR_PASSWORD@db.jjucyadatlpruinptwdk.supabase.co:5432/postgres?sslmode=require

# ============================================
# AUTHENTICATION
# ============================================

# JWT Secret for signing authentication tokens. 
# Use a long random string (32+ characters). Required in production.
# Generate with: openssl rand -base64 32
JWT_SECRET=your-super-secret-jwt-key-change-this-to-something-random-32-chars-minimum

# Alternative name for JWT_SECRET (either one works)
AUTH_SECRET=your-super-secret-jwt-key-change-this-to-something-random-32-chars-minimum

# ============================================
# PUBLIC URLs
# ============================================

# Local app URL
NEXT_PUBLIC_BASE_URL=http://localhost:3000

# Supabase public project values (optional, only needed if using Supabase client in browser)
NEXT_PUBLIC_SUPABASE_URL=https://jjucyadatlpruinptwdk.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_vcWrgdO6_1pB0CrmqrwcKQ_ZZv0I6Jf
NEXT_PUBLIC_SUPABASE_ANON_KEY=sb_publishable_vcWrgdO6_1pB0CrmqrwcKQ_ZZv0I6Jf

# ============================================
# SERVER SECRETS
# ============================================

# Optional server-only Supabase key. Do not expose in client code.
SUPABASE_SERVICE_ROLE_KEY=your-optional-service-role-key

# ============================================
# DATABASE PERFORMANCE & POOLING
# ============================================

# Maximum number of concurrent database connections
DATABASE_POOL_MAX=5

# Enable SSL for database connections (recommended for production)
DATABASE_SSL=true

# How long to wait for a database connection (milliseconds)
DATABASE_CONNECTION_TIMEOUT_MS=10000

# How long to keep idle database connections (milliseconds)
DATABASE_IDLE_TIMEOUT_MS=5000

# ============================================
# DEMO & DEVELOPMENT
# ============================================

# Set to 'true' to seed demo users on database initialization
# Demo users: admin@localadnetwork.com, advertiser@example.com, publisher@example.com
# Passwords: admin123, advertiser123, publisher123 (respectively)
# ⚠️ NEVER enable in production
SEED_DEMO_USERS=false

# Skip runtime schema setup (migrations will still need to be run manually)
DISABLE_RUNTIME_SCHEMA_SETUP=true

# Show API errors to frontend (development only, disable in production)
EXPOSE_API_ERRORS=false

# ============================================
# PRODUCTION ADMIN ACCOUNT
# ============================================
# Only used when running: npm run db:prod-admin
# Set these before running the production admin script

# Production admin email
ADMIN_EMAIL=admin@example.com

# Production admin password (must be 12+ characters)
ADMIN_PASSWORD=your-strong-password-at-least-12-characters

# Production admin name
ADMIN_FIRST_NAME=Admin
ADMIN_LAST_NAME=User

# ============================================
# OPTIONAL: IMAGE UPLOADS (CLOUDINARY)
# ============================================

# Cloudinary account name
CLOUDINARY_CLOUD_NAME=your-cloud-name

# Cloudinary API key
CLOUDINARY_API_KEY=your-api-key

# Cloudinary API secret
CLOUDINARY_API_SECRET=your-api-secret

# Maximum image upload size in MB
MAX_CAMPAIGN_IMAGE_SIZE_MB=5

# Cloudinary upload folder path
CLOUDINARY_UPLOAD_FOLDER=local-ads/campaign-images
